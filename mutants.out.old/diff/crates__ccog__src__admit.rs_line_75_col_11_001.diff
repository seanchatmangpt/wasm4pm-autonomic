 /// Composes four admission verdicts via bitwise OR.
 ///
 /// The result is admitted (`0`) iff *all four* inputs are admitted.
 #[must_use]
 #[inline(always)]
 pub const fn admit4(a: u64, b: u64, c: u64, d: u64) -> u64 {
-    a | b | c | d
+    a | b ^ /* ~ changed by cargo-mutants ~ */ c | d
 }
 
