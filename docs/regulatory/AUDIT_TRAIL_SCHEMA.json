{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Audit Trail Entry Schema",
  "description": "Machine-readable schema for immutable per-trace decision logs. Every system decision produces one entry. Entries are write-once, append-only, stored in tamper-evident distributed ledger (blockchain or cryptographically signed log).",
  "type": "object",
  "required": [
    "timestamp",
    "trace_id",
    "system_id",
    "input_hash",
    "output",
    "confidence",
    "audit_signature"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp (UTC) of decision. Example: 2026-04-28T14:32:15.123Z"
    },
    "trace_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{32}$",
      "description": "Unique trace identifier (MD5 hash of customer_id + request_id). Immutable link to this decision in the event log."
    },
    "system_id": {
      "type": "string",
      "pattern": "^sys-[0-9]{3}$",
      "description": "Unique system identifier (e.g., sys-001 for ELIZA-keyword classifier). Corresponds to model card in MODEL_CARD_TEMPLATE.md"
    },
    "input_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{32}$",
      "description": "SHA-256 hash of input data (first 32 chars for brevity). Enables input reproducibility without storing raw PII."
    },
    "output": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "approved",
            "rejected",
            "escalated",
            "pending_review",
            "error"
          ],
          "description": "Categorical decision output"
        },
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Continuous decision output (e.g., probability 0.0–1.0)"
        },
        {
          "type": "object",
          "properties": {
            "primary_category": {
              "type": "string"
            },
            "secondary_category": {
              "type": "string"
            },
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          },
          "description": "Structured decision with multiple fields"
        }
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence score (0.0–1.0). For symbolic systems: 0 (no rule) or 1 (rule fired). For learned models: posterior probability. For ensemble: (agreement_count / 10)."
    },
    "rule_fired": {
      "oneOf": [
        {
          "type": "string",
          "description": "For symbolic systems: rule identifier (e.g., 'eligibility_rule_001')"
        },
        {
          "type": "null",
          "description": "For learned models: null (rules do not apply)"
        }
      ]
    },
    "model_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semantic version of the system at decision time (e.g., 2.1.0). Enables rollback tracking."
    },
    "weight_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{32}$",
      "description": "For learned models: SHA-256 hash of model weights (first 32 chars). Enables detection of weight tampering."
    },
    "tier_executed": {
      "type": "string",
      "enum": [
        "tier_1",
        "tier_2",
        "tier_3"
      ],
      "description": "Execution tier of the decision. Tier 1: automatic (≥0.95 confidence, ≥9/10 agreement). Tier 2: confidence-gated (0.8–0.95). Tier 3: manual review (≤0.8)."
    },
    "ensemble_agreement": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "description": "Number of systems in the ensemble (out of 10) that agreed with this decision. Enables ensemble monitoring."
    },
    "ensemble_variance": {
      "type": "number",
      "minimum": 0,
      "description": "Variance of the ensemble: σ(system_outputs). Used for confidence bound estimation: output ± √(variance)."
    },
    "ood_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "description": "Out-of-distribution (OOD) detection score (0.0–5.0). Measured as Mahalanobis distance in feature space. >3.0 triggers rejection."
    },
    "ood_rejected": {
      "type": "boolean",
      "description": "True if OOD score > 3.0 and decision was rejected. False otherwise."
    },
    "latency_ms": {
      "type": "number",
      "minimum": 0,
      "description": "End-to-end decision latency in milliseconds (from input arrival to output generation)."
    },
    "data_governance_flag": {
      "type": "boolean",
      "description": "True if decision involves sensitive personal data (PII) and requires GDPR/CCPA compliance check."
    },
    "human_review_required": {
      "type": "boolean",
      "description": "True if confidence < 0.80 or ensemble agreement < 7/10 or OOD detected. Requires manual review before action."
    },
    "incident_id": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^INC-[0-9]{6}$",
          "description": "If this decision was part of an incident response, link to the incident ID."
        },
        {
          "type": "null"
        }
      ]
    },
    "audit_signature": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "HMAC-SHA256 signature of the entire entry (excluding this field). Computed by immutable audit service. Enables tamper detection."
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "number"
          },
          {
            "type": "boolean"
          }
        ]
      },
      "description": "Optional key-value metadata (e.g., customer_segment, request_type, approval_code)."
    }
  },
  "examples": [
    {
      "timestamp": "2026-04-28T14:32:15.123Z",
      "trace_id": "5a7f8c2e9b1d4e6f3a2c5e8f1a3b4c5d",
