PREFIX code: <https://chatmangpt.com/ontology/codegen#>
PREFIX rust: <https://chatmangpt.com/ontology/rust#>

SELECT ?crate ?name ?crate_path ?executionClass
WHERE {
  ?crate a code:RustCrate ;
         code:name ?name ;
         code:path ?crate_path .
  OPTIONAL { ?crate rust:executionClass ?executionClass . }
}
ORDER BY ?crate_path