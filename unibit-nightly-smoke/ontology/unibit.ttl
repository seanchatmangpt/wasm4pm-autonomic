@prefix ub: <https://chatmangpt.com/ontology/unibit#> .
@prefix rust: <https://chatmangpt.com/ontology/rust#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ub:Unibit a ub:Substrate ;
  ub:formalNotation "U_{1,n}" ;
  ub:law "truth stays resident; motion happens in scratch" ;
  ub:workBase 8 ;
  ub:memoryBase 64 .

ub:TruthRegion a ub:ResidentRegion ;
  ub:role ub:Truth ;
  ub:formalUniverse "U_{1,262144}" ;
  ub:bitCount 262144 ;
  ub:rustWords 4096 ;
  ub:rustType "UTruthBlock" ;
  rust:repr "C" ;
  rust:alignBits 512 .

ub:ScratchRegion a ub:ResidentRegion ;
  ub:role ub:Scratch ;
  ub:formalUniverse "U_{1,262144}" ;
  ub:bitCount 262144 ;
  ub:rustWords 4096 ;
  ub:rustType "UScratchpad" ;
  rust:repr "C" ;
  rust:alignBits 512 .

ub:L1Region a ub:ResidentPair ;
  ub:truth ub:TruthRegion ;
  ub:scratch ub:ScratchRegion ;
  ub:bitCount 524288 ;
  ub:rustType "UL1Region" ;
  rust:repr "C" ;
  rust:alignBits 512 ;
  ub:requiresPinning true ;
  ub:requiresPositionValidation true .

ub:WordCell a ub:WorkTier ;
  ub:formalUniverse "U_{1,64}" ;
  ub:workPower "8^2" ;
  ub:bitCount 64 ;
  ub:targetNs 10 ;
  ub:rustType "UCell" .

ub:SemanticLine a ub:WorkTier ;
  ub:formalUniverse "U_{1,512}" ;
  ub:workPower "8^3" ;
  ub:bitCount 512 ;
  ub:targetNs 100 ;
  ub:rustWords 8 .

ub:AttentionBlock a ub:WorkTier ;
  ub:formalUniverse "U_{1,4096}" ;
  ub:workPower "8^4" ;
  ub:bitCount 4096 ;
  ub:targetNs 200 ;
  ub:rustWords 64 .

ub:ActiveTile a ub:WorkTier ;
  ub:formalUniverse "U_{1,32768}" ;
  ub:workPower "8^5" ;
  ub:bitCount 32768 ;
  ub:targetNs 500 ;
  ub:rustWords 512 .

ub:ActiveUniverse a ub:MemoryTier ;
  ub:formalUniverse "U_{1,262144}" ;
  ub:memoryPower "64^3" ;
  ub:bitCount 262144 ;
  ub:rustWords 4096 .

ub:MeaningField a ub:MemoryTier ;
  ub:formalUniverse "U_{1,16777216}" ;
  ub:memoryPower "64^4" ;
  ub:bitCount 16777216 ;
  ub:rustWords 262144 .