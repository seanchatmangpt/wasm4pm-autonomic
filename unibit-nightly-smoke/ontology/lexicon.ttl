@prefix lex: <https://chatmangpt.com/ontology/lexicon#> .
@prefix code: <https://chatmangpt.com/ontology/codegen#> .

lex:UnibitLexicon a lex:Lexicon ;
  lex:allows "8^n" ;
  lex:allows "64^n" ;
  lex:allows "U_{1,n}" ;
  lex:allows "bits" ;
  lex:allows "truth" ;
  lex:allows "scratch" ;
  lex:allows "motion" ;
  lex:allows "delta" ;
  lex:allows "receipt" .

lex:ForbiddenStorageNoun a lex:ForbiddenToken ;
  lex:encodedToken "98,121,116,101" ;
  lex:reason "Substrate docs and code must remain bit-native." ;
  lex:severity "error" .