# matrix-tv environment variables
# Copy to .env.local for development.

# Port the Next.js server binds to (standalone / Docker).
PORT=3000

# Hostname for standalone server. Use 0.0.0.0 inside containers.
HOSTNAME=0.0.0.0

# Next.js telemetry — off by default in Docker, opt-in here.
NEXT_TELEMETRY_DISABLED=1

# Future: when the napi-rs bridge lands, the path or URL to the
# unibit cdylib used by the /api/motion route handler.
# UNIBIT_DYLIB_PATH=../../../unibit/target/release/libunibit_nif.dylib
